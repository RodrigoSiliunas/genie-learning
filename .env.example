# Genie Learning environment variables
#
# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Gemini API (optional — only required for podcast audio generation)
# ---------------------------------------------------------------------------

# Your Google AI Studio API key for multi-speaker TTS.
# Get one at: https://aistudio.google.com/
# If unset or left as the placeholder, podcast audio generation is skipped
# silently and the rendered HTML shows an "audio coming soon" banner.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini TTS model to use. Defaults to gemini-2.5-flash-preview-tts.
# Only change this if you know the target model supports multi-speaker
# speech generation.
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Output audio format. Currently only "wav" is emitted (24 kHz mono PCM
# wrapped in RIFF/WAVE). MP3 support is on the roadmap but requires ffmpeg.
GEMINI_PODCAST_OUTPUT_FORMAT=wav
